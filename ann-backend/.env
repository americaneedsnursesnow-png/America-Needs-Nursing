PORT=3001

# production | development — affects JSON vs pretty HTTP logs and CORS enforcement
# NODE_ENV=development
# LOG_LEVEL=info

# CORS: comma-separated browser origins. If unset, any origin is allowed (local dev only).
# When NODE_ENV=production, set CORS_ORIGINS and/or FRONTEND_URL (FRONTEND_URL origin is merged in).
# Production: Next.js site origin(s), e.g. https://americaneedsnurses.com (add https://www.… if you use www)
CORS_ORIGINS=https://americaneedsnurses.com

# Behind NGINX / ALB / Cloudflare: trust X-Forwarded-Proto / X-Forwarded-For (HTTPS, client IP).
# Set RATE_LIMIT_TRUST_PROXY=true as well when this is true.
# TRUST_PROXY=true

# Request timeout for HTTP handlers (ms, minimum 1000). Socket.IO polling is excluded.
# REQUEST_TIMEOUT_MS=55000

# gzip/brotli-style compression for JSON (skipped for /health, /metrics).
# ENABLE_RESPONSE_COMPRESSION=true

# TypeORM warns in logs when a query exceeds this many ms (set 0 to disable).
# DATABASE_SLOW_QUERY_MS=2500

# Postgres pool (node-postgres via TypeORM `extra`). Increase under high RPS; stay below DB max_connections.
# DATABASE_POOL_MAX=36

# Optional CSP headers on GET /files/* (uploads). Main API responses keep CSP off (JSON + Socket.IO).
# HELMET_CSP_ON_FILES=true

# Health checks (excluded from rate limits and pino access logs): GET /health, /health/ready, /health/db

# Required for auth (use a long random string in production)
JWT_SECRET=b1307c3f36e7dbb8a2e774ad6e925819e2cb07630293991feef184754c65dc55
JWT_EXPIRES_IN=7d

# Database — same values are used by docker-compose for Postgres (via DATABASE_*).
# Docker: run `docker compose up -d`, then DATABASE_PORT=5433 (Postgres on localhost:5433).
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=12345
DATABASE_NAME=ann


# pgAdmin (docker-compose): login defaults — PGADMIN_DEFAULT_EMAIL / PGADMIN_DEFAULT_PASSWORD
# Create role "ann" on native Postgres: scripts/setup-local-postgres.sql

TYPEORM_SYNCHRONIZE=true

# node-postgres pool (TypeORM `extra`). Tune for your DB tier and API concurrency.
# DATABASE_POOL_MAX=20
# DATABASE_POOL_MIN=2
# DATABASE_POOL_IDLE_MS=30000
# DATABASE_POOL_CONN_TIMEOUT_MS=10000

# Nurse resume PDFs and account profile photos: stored under
# <UPLOADS_DIR>/nurse-resumes/... and <UPLOADS_DIR>/profile-photos/<userId>/...
# Served at GET /files/... (defaults to ./uploads in project root)
# UPLOADS_DIR=

# Redis cache — `docker compose up -d` exposes Redis on localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Optional: redis://:password@host:6379
# REDIS_URL=

# Multi-instance WebSockets: share rooms/events across API replicas (same Redis as Bull/cache).
# SOCKET_IO_REDIS_ADAPTER=true

# Prometheus default process metrics at GET /metrics (404 when disabled). Scrape from your monitor stack.
# METRICS_ENABLED=true

# Process layout: this app runs HTTP + WebSockets + Bull processors in one Node process.
# For very high scale, run additional replicas with SOCKET_IO_REDIS_ADAPTER=true, and/or split Bull
# workers into a separate deployment using the same image (requires extracting @Processor providers).

# BullMQ (same Redis as cache/rate-limit). Keys use prefix ann:bull — docker-compose Redis uses
# maxmemory 512mb + maxmemory-policy=noeviction so jobs are not LRU-evicted; use the same in prod.
# Blog publish → nurses email runs as a background job on queue "blog-publish-mail".

# Rate limiting
RATE_LIMIT_REDIS_NAMESPACE=ann:ratelimit
RATE_LIMIT_TRUST_PROXY=false
RATE_LIMIT_GLOBAL_LIMIT=100
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_OTP_LIMIT=3
RATE_LIMIT_OTP_WINDOW_SECONDS=300
RATE_LIMIT_PASSWORD_RESET_LIMIT=3
RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=600
RATE_LIMIT_VIOLATION_WINDOW_SECONDS=3600
RATE_LIMIT_BLOCK_AFTER_VIOLATIONS=3
RATE_LIMIT_BLOCK_DURATION_SECONDS=900
RATE_LIMIT_CAPTCHA_ENABLED=true
RATE_LIMIT_CAPTCHA_AFTER_VIOLATIONS=2
RATE_LIMIT_CAPTCHA_TTL_SECONDS=1800

# Example OTP flow
AUTH_OTP_TTL_SECONDS=600

# Outbound email (blog publish → notify all registered nurses for this clientName)
# Provider: smtp (default) or ses. If provider settings are missing, no mail is sent.
# MAIL_PROVIDER=smtp
#
# SMTP provider settings
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
#
# AWS SES provider settings
# MAIL_PROVIDER=ses
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# Sender address (must be a verified SES identity in your account/region when MAIL_PROVIDER=ses)
# MAIL_FROM="America Needs Nurses <noreply@example.com>"

# Admin CSV import of nurse emails (`POST /admin/nurse-import/csv`). Default 10000 if unset.
NURSE_CSV_IMPORT_MAX_EMAILS=10000

# Stripe (employer checkout for job packages). Webhook URL: POST /payments/stripe/webhook
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: default success/cancel URLs when the client omits them in checkout
# (email links — welcome, job published, password reset — also use this base)
FRONTEND_URL=https://americaneedsnurses.com
# Optional: business name + colors in Checkout (embedded + hosted); defaults to “America Needs Nurses” + red CTA
# STRIPE_CHECKOUT_DISPLAY_NAME=America Needs Nurses
