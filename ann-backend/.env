PORT=3001
NODE_ENV=development
# Local Next.js dev server (default port 3003). Production: add your HTTPS site origins (comma-separated).
CORS_ORIGINS=https://americaneedsnurses.com/
# CORS_ORIGINS=http://localhost:3003,http://127.0.0.1:3003

# Behind NGINX / ALB / Cloudflare: trust X-Forwarded-Proto / X-Forwarded-For (HTTPS, client IP).
TRUST_PROXY=true
# Request timeout for HTTP handlers (ms, minimum 1000). Socket.IO polling is excluded.
REQUEST_TIMEOUT_MS=55000
# gzip/brotli-style compression for JSON (skipped for /health, /metrics).
ENABLE_RESPONSE_COMPRESSION=true
# TypeORM warns in logs when a query exceeds this many ms (set 0 to disable).
DATABASE_SLOW_QUERY_MS=2500
# Postgres pool (node-postgres via TypeORM `extra`). Increase under high RPS; stay below DB max_connections.
DATABASE_POOL_MAX=36
# Optional CSP headers on GET /files/* (uploads). Main API responses keep CSP off (JSON + Socket.IO).
HELMET_CSP_ON_FILES=true
# JWT signing secret (use a long random string in production)
JWT_SECRET=b1307c3f36e7dbb8a2e774ad6e925819e2cb07630293991feef184754c65dc55
JWT_EXPIRES_IN=7d
# Postgres credentials
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=12345
DATABASE_NAME=ann

TYPEORM_SYNCHRONIZE=true

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

RATE_LIMIT_REDIS_NAMESPACE=ann:ratelimit
RATE_LIMIT_TRUST_PROXY=false
RATE_LIMIT_GLOBAL_LIMIT=100
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_OTP_LIMIT=3
RATE_LIMIT_OTP_WINDOW_SECONDS=300
RATE_LIMIT_PASSWORD_RESET_LIMIT=3
RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=600
RATE_LIMIT_VIOLATION_WINDOW_SECONDS=3600
RATE_LIMIT_BLOCK_AFTER_VIOLATIONS=3
RATE_LIMIT_BLOCK_DURATION_SECONDS=900
RATE_LIMIT_CAPTCHA_ENABLED=true
RATE_LIMIT_CAPTCHA_AFTER_VIOLATIONS=2
RATE_LIMIT_CAPTCHA_TTL_SECONDS=1800

AUTH_OTP_TTL_SECONDS=600

NURSE_CSV_IMPORT_MAX_EMAILS=10000

# Outbound mail — must set MAIL_PROVIDER=ses to use AWS (default is smtp, which needs SMTP_HOST).
MAIL_PROVIDER=ses
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAY4SXWARGOHVGFL4S
AWS_SECRET_ACCESS_KEY=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
# MAIL_FROM must be a verified identity in this AWS account/region (not an arbitrary @gmail.com unless verified in SES).
MAIL_FROM="America Needs Nurses <americaneedsnursesnow@gmail.com>"
# Same IAM user as SES — enable S3 uploads (restart API after changing).
STORAGE_DRIVER=s3
AWS_S3_BUCKET_NAME=americaneedsnurses-uploads
# S3_BUCKET=americaneedsnurses-uploads

STRIPE_SECRET_KEY=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

FRONTEND_URL=https://americaneedsnurses.com/
# FRONTEND_URL=http://localhost:3003

STRIPE_CHECKOUT_DISPLAY_NAME=America Needs Nurses
