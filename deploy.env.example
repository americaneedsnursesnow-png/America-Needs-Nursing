# Copy to deploy.env (gitignored). Values below are examples — replace with your real domain and secrets.
#
# DNS: point APP_DOMAIN and API_DOMAIN (A or CNAME) to your server’s public IP before starting the stack.
#
# Start: copy this file to deploy.env, then run from repo root:
#   docker compose --env-file deploy.env up -d --build

# --- Nginx (required) — hostnames only, no scheme or path
APP_DOMAIN=www.americaneedsnurses.com
API_DOMAIN=api.americaneedsnurses.com

# --- Database (required)
DATABASE_USER=postgres
DATABASE_PASSWORD=change-me-strong-password
DATABASE_NAME=ann

# --- NestJS (required in production)
NODE_ENV=production
JWT_SECRET=replace-with-long-random-hex-or-string

# Comma-separated browser origins for the Next.js site (must match how users open the app)
CORS_ORIGINS=https://www.americaneedsnurses.com,https://americaneedsnurses.com

# Stripe redirects and emails — use your public app URL
FRONTEND_URL=https://www.americaneedsnurses.com

# First-time schema: set true once if you have no migrations applied yet, then set false
TYPEORM_SYNCHRONIZE=false

# --- Frontend image build (passed as Docker build-args; must be public https URLs)
NEXT_PUBLIC_API_BASE_URL=https://api.americaneedsnurses.com
NEXT_PUBLIC_NEST_SOCKET_ORIGIN=https://api.americaneedsnurses.com
NEXT_PUBLIC_ANN_CLIENT_NAME=ann
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SOCKET_IO_UPGRADE=true

# Optional: single-instance sockets; set true if you scale API replicas (requires Redis pub/sub)
# SOCKET_IO_REDIS_ADAPTER=true
