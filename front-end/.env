NEXT_PUBLIC_API_BASE_URL=https://api.americaneedsnurses.com
# Local: Nest `npm run start:dev` on port 3001; Next `npm run dev` on 3003
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001
NEXT_PUBLIC_SOCKET_IO_UPGRADE=true
NEXT_PUBLIC_ANN_CLIENT_NAME=ann
NEXT_PUBLIC_APP_URL=https://americaneedsnursing.com
# Stripe publishable key — set this on the server directly, never commit live keys to git.
# On your VPS: add to /etc/environment or pm2 ecosystem config.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=