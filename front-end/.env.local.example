# Copy to .env.local and adjust. Frontend default port is 3003; Nest ann-backend default is 3000.

# If you see 503 on /api/nest/* (e.g. account/me): ann-backend must be running, and these URLs must match its PORT (see ann-backend .env PORT=).

# Optional — SSR/build only. The browser always uses same-origin /api/nest (see src/lib/api/env.ts).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Used by app/api/nest proxy and by server-side fetch when NEXT_PUBLIC_API_BASE_URL is unset.
# Must match Nest listen address (npm run start:dev in ann-backend). Change port if PORT in ann-backend is not 3000.
API_UPSTREAM_URL=http://127.0.0.1:3000

# Browser connects Socket.IO here (WebSockets cannot go through the Next /api/nest proxy). Use the same host you open in the browser (localhost vs 127.0.0.1) to avoid WS upgrade issues. Port must match Nest PORT.
NEXT_PUBLIC_NEST_SOCKET_ORIGIN=http://localhost:3000

# Socket.IO defaults to long-polling only (no WS upgrade) for reliability. Set to "true" to allow upgrade to WebSocket after connect.
# NEXT_PUBLIC_SOCKET_IO_UPGRADE=true....

# Must match backend user tenant (see CreateUserDto / register clientName)
NEXT_PUBLIC_ANN_CLIENT_NAME=ann

# Stripe.js (Embedded Checkout iframe on employer package page). Must match the mode of STRIPE_SECRET_KEY on ann-backend (test vs live).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51Setj6PAQYRVyVF5ccH6WFYdABO9VQmFZXei8ERPSfjrP7oQd7IwvjPc1bxy27sZiafniarPjit8xumbjlWMY0WL00qrrJij2j

# --- Stripe checkout POST /api/nest/billing/stripe/checkout-session returns 400 ---
# In DevTools → Network → checkout-session → Response: read Nest’s JSON `message`.
# Typical fixes (ann-backend): STRIPE_SECRET_KEY set; DTO @IsUrl({ require_tld: false }) for successUrl/cancelUrl
# when using http://localhost:…; package price ≥ $0.50 USD (or valid Stripe price_… ID); company/package allowed for checkout.
